# ── 独立后端服务 ──
PORT=8787
HOST=127.0.0.1
# 管理后台登录密码(生产务必修改)
ADMIN_PASSWORD=change-me-in-env
# 签名 cookie 密钥(生产用 `openssl rand -hex 32` 生成)
COOKIE_SECRET=change-me-random-32-bytes
# BOSS 自动化机器入库 POST /api/candidates 的 Bearer token(留空则只允许管理员登录后入库)
INGEST_TOKEN=
# 数据库与备份路径(生产挂持久卷;切勿放 iCloud 同步目录)
# DATABASE_PATH=/app/data/interview.db
# BACKUP_DIR=/app/backups
BACKUP_KEEP_DAYS=30

# ── 大模型(OpenAI 兼容) ──
# 题目生成/追问/评判/报告/初筛:DeepSeek 或 小米 MiMO
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-pro
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# ── 语音转写(阶段2 批量转写) ──
# 阿里百炼 DashScope Paraformer
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=paraformer-v2

# ── 飞书(过渡期只读,后退役) ──
LARK_CLI_PATH=/path/to/lark-cli
FEISHU_TENANT_URL=https://example.feishu.cn
LARK_CLI_NO_PROXY=1
