{
  "name": "interview-copilot-app",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "concurrently -k -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run clean && vite build",
    "start": "cross-env NODE_ENV=production SERVE_STATIC=1 tsx server/index.ts",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "migrate": "tsx scripts/migrate-to-sqlite.mts",
    "feishu:create-resume-library": "node scripts/create-feishu-resume-library.mjs",
    "feishu:create-unresponded-talent-library": "node scripts/create-feishu-unresponded-talent-library.mjs",
    "feishu:backfill-resumes": "node scripts/backfill-resume-text.mjs",
    "feishu:upsert-boss-resume": "node scripts/upsert-boss-resume-to-feishu-library.mjs",
    "feishu:upsert-boss-unresponded-talent": "node scripts/upsert-boss-resume-to-feishu-library.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
